# --- Public (sent to the browser; safe to expose) ----------------------------
# The Supabase project URL.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Supabase publishable key (the new sb_publishable_... key, NOT the legacy anon key
# and NOT the service role key). Safe to ship to the browser; RLS enforces access.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me

# --- Server-only (never sent to the browser; never commit real values) -------
# Direct Postgres connection string. Used by migrations and integration tests.
SUPABASE_DATABASE_URL=postgresql://postgres:replace_me@host:5432/postgres
# Supabase service role key. Bypasses RLS; only used server-side from
# src/persistence/supabase-admin.ts. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=replace_me_eyJhbGciOi...
# Random ≥32-char string used to authenticate Vercel Cron requests.
CRON_SECRET=replace_me_with_openssl_rand_hex_32
